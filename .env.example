# ── Core ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...            # fallback for non-sensitive subagents

# ── LLM model selection ───────────────────────────────────────────────────────
LLM_HEAVY=claude-opus-4-7               # chain reasoning, validator, report
LLM_LIGHT=claude-haiku-4-5-20251001    # classification, extraction subtasks
LLM_MID=claude-sonnet-4-6              # general agents

# ── Crypto ───────────────────────────────────────────────────────────────────
FERNET_KEY=                             # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=zwan
POSTGRES_USER=zwan
POSTGRES_PASSWORD=changeme_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── Service ports ─────────────────────────────────────────────────────────────
BACKEND_PORT=8731
FRONTEND_PORT=3000

# ── Per-engagement budget cap (USD) ───────────────────────────────────────────
LLM_BUDGET_DEFAULT=5.00

# ── Burp Pro REST API (optional) ─────────────────────────────────────────────
BURP_API_URL=http://127.0.0.1:1337
BURP_API_KEY=

# ── Caido (alternative proxy) ─────────────────────────────────────────────────
CAIDO_API_URL=http://127.0.0.1:8080
CAIDO_API_KEY=

# ── OAST / Interactsh ─────────────────────────────────────────────────────────
INTERACTSH_SERVER=                      # leave empty to use public interactsh.com
INTERACTSH_TOKEN=

# ── Recon tools (resolved at runtime inside tools-image) ─────────────────────
SUBFINDER_API_KEYS=                     # JSON: {"securitytrails":"...", "shodan":"..."}
CHAOS_KEY=

# ── ZWAN-AGENT (local autonomous agent, port 8788) ───────────────────────────
ZWAN_AGENT_PORT=8788
NEXT_PUBLIC_AGENT_WS=ws://127.0.0.1:8788/ws
NEXT_PUBLIC_AGENT_HTTP=http://127.0.0.1:8788
ZWAN_AUDIT_DB=~/.zwan-codex/audit.db
ZWAN_STORE_OUTPUT=0          # set to 1 to store full stdout/stderr in audit DB
ZWAN_MAX_ITERS=25
ZWAN_SESSION_BUDGET_SEC=1800
OLLAMA_HOST=                 # e.g. http://127.0.0.1:11434 for LLM fallback
OLLAMA_MODEL=llama3.1:8b
